# -*- mode: gitconfig -*-
[core]
	excludesfile = ~/.gitignore_global
	autocrlf = false
	ignorecase = false
	safecrlf = warn
	editor = emacsclient -a=\\\"\\\"
	quotepath = false
[color]
	branch = auto
	diff = auto
	interactive = auto
	status = auto
[pull]
	rebase = false
[push]
	default = current
[pager]
    diff = delta
    show = delta
    log = delta
    blame = delta
    reflog = delta
[interactive]
    diffFilter = delta --color-only
[diff]
	tool = delta
